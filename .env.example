# e-conomic REST API
ECONOMIC_APP_SECRET_TOKEN=
ECONOMIC_AGREEMENT_GRANT_TOKEN=

# Supabase (projekt → Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
# Til sync-script og server-RPC (hold hemmelig)
SUPABASE_SERVICE_ROLE_KEY=
# Valgfrit: hvis du vil kalde Supabase direkte fra browser med RLS
SUPABASE_ANON_KEY=

# Server
PORT=3000

# Hemmelig nøgle til login-session (cookie + API-token). Påkrævet på Vercel/produktion, min. 16 tegn — fx output fra: openssl rand -hex 32
FRILAND_SESSION_SECRET=

# Første admin oprettes automatisk ved første serverstart (data/users.json), medmindre filen findes:
# Standard: nikolaj@idevaerket.dk — overskriv med:
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=

# Udgående mail til bogholder (påkrævet for rigtig mail — ellers simuleres afsendelse i server-log)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Friland <noreply@ditdomæne.dk>"

# Valgfrit: automatisk sync mens serveren kører (ms, fx 3600000 = 1 time)
# SUPABASE_AUTO_SYNC_MS=

# Valgfrit: sync kun bestemte regnskabsår (kommasepareret, fx 2024,2025)
# SYNC_ACCOUNTING_YEARS=

# Valgfrit: kun posteringer i datointerval (YYYY-MM-DD) — filtreres efter hent
# SYNC_FROM_DATE=
# SYNC_TO_DATE=
