# e-conomic API tokens
# Opret en app på https://www.e-conomic.com/developer/connect
# og brug Installation URL til at få AgreementGrantToken fra brugeren.

ECONOMIC_APP_SECRET_TOKEN=demo
ECONOMIC_AGREEMENT_GRANT_TOKEN=demo

# Ved produktion: Erstat "demo" med dine rigtige tokens.
# Brug aldrig "demo" i produktion – det giver kun adgang til e-conomics demo-data.

# Valgfri: Port for serveren (default: 3000)
# PORT=3000
